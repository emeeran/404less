# =============================================================================
# 404scout Environment Configuration
# =============================================================================
# Copy this file to .env and update values for your environment.
# NEVER commit .env to version control.
# =============================================================================

# Environment mode (development, staging, production)
ENVIRONMENT=development

# =============================================================================
# JWT Configuration
# =============================================================================
# REQUIRED in production! Generate a secure secret with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-secret-key-here

# =============================================================================
# Database Configuration
# =============================================================================
# SQLite (default for development)
DATABASE_URL=sqlite+aiosqlite:///./sdd.db

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/sdd

# Fail if database is unavailable at startup (recommended for production)
DB_REQUIRED=false

# Log SQL queries (useful for debugging)
SQL_ECHO=false

# Connection pool settings (PostgreSQL only)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# =============================================================================
# Email Configuration
# =============================================================================
# Backend: "console" (dev) or "smtp" (production)
EMAIL_BACKEND=console

# SMTP settings (only used when EMAIL_BACKEND=smtp)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# Sender email address
EMAIL_FROM=noreply@example.com

# Base URL for email links (REQUIRED in production - must not be localhost)
BASE_URL=http://localhost:8000

# =============================================================================
# Rate Limiting Configuration
# =============================================================================
# Format: count/period (second, minute, hour, day)
RATE_LIMIT_SCAN_CREATE=10/hour
RATE_LIMIT_LOGIN=20/minute
RATE_LIMIT_REGISTER=5/hour
RATE_LIMIT_PASSWORD_RESET=3/hour

# =============================================================================
# Crawler Configuration
# =============================================================================
CRAWLER_MAX_CONCURRENT=5
CRAWLER_MIN_DELAY=0.1
CRAWLER_TIMEOUT=30
CRAWLER_MAX_REDIRECTS=10
CRAWLER_MAX_DEPTH=10
